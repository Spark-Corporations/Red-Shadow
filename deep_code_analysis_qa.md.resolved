class PhaseAgentBase:
    async def run(self) -> dict:
        # 1. KG-dən əvvəlki phase-lərin nəticələrini oxu
        context = self._load_context_from_kg()

        # 2. Bu phase-in işini icra et
        result = await self.execute()

        # 3. Nəticəni KG-yə yaz
        self._write_to_kg(result)

        # 4. Xarici validasiya
        is_valid = self._validate(result)

        return result
