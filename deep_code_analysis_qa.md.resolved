def generate(self, finding, validation) -> str:
    return f"""
    WHY (Root Cause):    {finding.get('root_cause')}
    WHAT (Vulnerability): CVE: {finding.get('cve')}, CVSS: {finding.get('cvss')}
    HOW (Exploitation):  {self._format_exploitation_path(finding.get('steps'))}
    PROOF (Evidence):    {self._format_proof(validation.get('proof'))}
    FIX (Recommendation): Immediate + Long-term
    """
```

